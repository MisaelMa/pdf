{
  "name": "@pdf.js/vue",
  "version": "0.1.0",
  "description": "Vue 3 integration for pdfcraft — reactive PDF generation and viewer",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "echo 'no linter configured'"
  },
  "dependencies": {
    "@pdf.js/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "pdfjs-dist": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "pdfjs-dist": {
      "optional": true
    }
  },
  "devDependencies": {
    "vue": "^3.5.13",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}

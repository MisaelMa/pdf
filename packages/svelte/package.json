{
  "name": "@pdf.js/svelte",
  "version": "0.1.0",
  "description": "Svelte integration for pdfcraft — stores and utilities for PDF generation",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "echo 'no linter configured'"
  },
  "dependencies": {
    "@pdf.js/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}

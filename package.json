{
  "private": true,
  "name": "pdf.js",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:www": "pnpm --filter pdf-www dev",
    "dev:astro": "pnpm --filter astro-app dev",
    "preview:www": "pnpm --filter pdf-www preview",
    "preview:astro": "pnpm --filter astro-app preview",
    "test": "vitest",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "vitest": "^3.0.0"
  }
}

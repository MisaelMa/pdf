---
// SSR page — the PDF is generated server-side via /api/pdf
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PDFCraft — Astro Demo</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #f8f9fa;
      display: flex;
      flex-direction: column;
      height: 100vh;
      padding: 16px;
      gap: 12px;
    }
    h2 { white-space: nowrap; }
    .toolbar { display: flex; align-items: center; gap: 12px; }
    iframe {
      flex: 1;
      border: none;
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <div class="toolbar">
    <h2>Astro Demo</h2>
    <span style="color: #666; font-size: 14px">PDF generated server-side with @pdfcraft/core</span>
  </div>
  <iframe src="/api/pdf" title="PDF Viewer" />
</body>
</html>
